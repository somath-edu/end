---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import katex from 'katex';

export async function getStaticPaths() {
	const vaultPath = path.join(process.cwd(), '../vault/m2-1-final');
	const files = fs.readdirSync(vaultPath);
	const targetFile = files.find(f => f.normalize('NFC').includes('중2 기말고사 대비'.normalize('NFC')));
	if (!targetFile) return [];
	const content = fs.readFileSync(path.join(vaultPath, targetFile), 'utf-8');
	
	const studySections = content.split('## 📘 [마스터 페이지]').slice(1);
	return studySections.map((_, idx) => ({
		params: { id: (idx + 1).toString() }
	}));
}

const { id } = Astro.params;
const vaultPath = path.join(process.cwd(), '../vault/m2-1-final');
const files = fs.readdirSync(vaultPath);
const targetFile = files.find(f => f.normalize('NFC').includes('중2 기말고사 대비'.normalize('NFC')));
if (!targetFile) throw new Error(`File not found in ${vaultPath}`);
const content = fs.readFileSync(path.join(vaultPath, targetFile), 'utf-8');

// --- Pre-rendering Logic (SSR) ---
function renderInlineMath(text: string): string {
	return text.replace(/\$([^\$\n]+?)\$/g, (_, tex) => {
		try {
			return `<span class="math-inline">${katex.renderToString(tex.trim(), { displayMode: false, output: 'html', throwOnError: false })}</span>`;
		} catch { return tex; }
	});
}

function renderDisplayMath(text: string): string {
	return text.replace(/\$\$(.*?)\$\$/gs, (_, tex) => {
		try {
			return `<div class="math-display">${katex.renderToString(tex.trim(), { displayMode: true, output: 'html', throwOnError: false })}</div>`;
		} catch { return tex; }
	});
}

function processContent(raw: string) {
	// 1. Basic Markdown-like cleaning
	let cleaned = raw
		.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') // Bold
		.replace(/^> (.*)$/gm, '<blockquote>$1</blockquote>'); // Blockquote

	// 2. Custom Components
	// Star Points
	cleaned = cleaned.replace(/★ (.*)/g, '<div class="star-item"><span class="star-icon">★</span> $1</div>');
	
	// 3. Math Rendering
	const choiceMatch = cleaned.match(/\n(①)/);
	const displayMathMatch = cleaned.match(/\n\$\$/);
	const blankLineMatch = cleaned.match(/\n\n/);

	const candidates: number[] = [];
	if (choiceMatch?.index !== undefined) candidates.push(choiceMatch.index);
	if (displayMathMatch?.index !== undefined) candidates.push(displayMathMatch.index);
	if (blankLineMatch?.index !== undefined) candidates.push(blankLineMatch.index);

	let instruction = cleaned;
	let rest = '';

	if (candidates.length > 0) {
		const splitAt = Math.min(...candidates);
		instruction = cleaned.substring(0, splitAt).trimEnd();
		rest = cleaned.substring(splitAt).trim();
	}

	const instrHTML = renderInlineMath(instruction);
	let restHTML = renderDisplayMath(rest);
	restHTML = renderInlineMath(restHTML);
	
	const parts = restHTML.split(/(<div class="math-display">.*?<\/div>)/gs);
	restHTML = parts.map(p =>
		p.startsWith('<div class="math-display">') ? p : p.replace(/\n/g, '<br/>')
	).join('');

	return `<div class="prob-instruction"><div class="instr-text">${instrHTML}</div></div>` +
		(restHTML ? `<div class="prob-content">${restHTML}</div>` : '');
}

// --- Parse Study Pages ---
const studySectionsRaw = content.split('## 📘 [마스터 페이지]').slice(1);
const studySections = studySectionsRaw.map(section => {
	const lines = section.split('\n');
	const title = lines[0].trim();
	const body = lines.slice(1).join('\n').trim();
	const parts = body.split('### ✍️ 유사 문제 연습');
	const conceptRaw = parts[0].replace('### 💡 핵심 개념 정리', '').trim();
	const practiceRaw = parts[1] || '';
	
	return { 
		title, 
		concept: processContent(conceptRaw), 
		practice: processContent(practiceRaw),
		rawConcept: conceptRaw,
		rawPractice: practiceRaw
	};
});

const currentIdx = parseInt(id || '1') - 1;
const section = studySections[currentIdx];

if (!section) throw new Error(`Study section ${id} not found`);

// --- JSON-LD for AEO/GEO ---
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "LearningResource",
	"name": section.title,
	"description": `중학교 2학년 수학 기말고사 대비를 위한 ${section.title} 핵심 개념 정리 및 연습 문제입니다.`,
	"learningResourceType": "Concept Summary and Practice",
	"educationalLevel": "Middle School Grade 2",
	"about": section.title.split(':')[1]?.trim() || "수학"
};
---

<Layout title={`마스터 ${id} - ${section.title.split(':')[1]?.trim()}`}>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<div class="paper-stack">
		<div class="paper study-page" id={`page-study-${id}`}>
			<div class="content-border">
				<div class="watermark">MASTER PLAN : CONCEPT & PRACTICE</div>
				
				<header class="study-header">
					<div class="header-tag">MASTER PAGE {String(id).padStart(2, '0')}</div>
					<h2 class="study-title">{section.title}</h2>
				</header>

				<div class="study-content">
					<div class="concept-section">
						<div class="section-badge"><span class="badge-icon">⭐</span> 핵심 개념 정리</div>
						<div class="concept-box prob-body" set:html={section.concept}></div>
					</div>

					<div class="practice-section">
						<div class="section-badge"><span class="badge-icon">✍️</span> 유사 문제 연습</div>
						<div class="practice-box prob-body" set:html={section.practice}></div>
					</div>

					<div class="solving-space">
						<div class="space-label">MEMO / 풀이 공간</div>
						<div class="dotted-area"></div>
					</div>
				</div>

				<footer class="exam-footer">
					<div class="footer-line"></div>
					<div class="footer-row">
						<span class="brand">Somath Digital Library</span>
						<span class="page-num">{parseInt(id || '1') + 1} / {studySections.length + 1}</span>
						<span class="copy">© 2026 Math Basic Project</span>
					</div>
				</footer>
			</div>
		</div>
	</div>
</Layout>

<style>
	:root {
		--ink: #1e293b;
		--paper: #fff;
		--point-blue: #2563eb;
		--bg-blue: #f8fafc;
	}

	.paper {
		background: var(--paper);
		color: var(--ink);
		padding: 40px;
		box-sizing: border-box;
		min-height: 297mm;
		width: 100%;
		max-width: 210mm;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
	}

	.paper-stack {
		display: flex;
		justify-content: center;
		padding: 2rem 0;
	}

	/* Study Page Styles */
	.study-header {
		border-bottom: 2px solid var(--ink);
		margin-bottom: 2rem;
		padding-bottom: 0.8rem;
	}
	.header-tag {
		font-family: sans-serif;
		font-size: 0.85rem;
		font-weight: 800;
		color: var(--point-blue);
		letter-spacing: 0.1em;
	}
	.study-title {
		font-size: 2rem;
		margin-top: 0.4rem;
		color: #0f172a;
		font-weight: 800;
	}

	.study-content {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.section-badge {
		display: inline-flex;
		align-items: center;
		background: #0f172a;
		color: #fff;
		padding: 6px 16px;
		border-radius: 20px 20px 20px 0;
		font-size: 1rem;
		font-weight: bold;
		margin-bottom: 1rem;
		box-shadow: 3px 3px 0px var(--point-blue);
	}
	.badge-icon { margin-right: 6px; }

	.concept-box {
		background: var(--bg-blue);
		border: 1.5px solid #e2e8f0;
		border-radius: 12px;
		padding: 2rem;
		line-height: 1.8;
		font-size: 1.15rem;
		position: relative;
	}

	/* Star Items */
	:global(.star-item) {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		margin-bottom: 0.8rem;
		font-weight: 600;
	}
	:global(.star-icon) {
		color: #f59e0b;
		font-size: 1.2rem;
	}

	/* Blockquote (Summary Box) */
	:global(blockquote) {
		margin: 1.5rem 0;
		padding: 1.2rem 1.5rem;
		background: #fff;
		border: 2px dashed var(--point-blue);
		border-radius: 8px;
		font-weight: 700;
		color: var(--point-blue);
	}

	:global(.prob-instruction) {
		display: block;
		margin-bottom: 0.5rem;
	}
	:global(.prob-content) {
		margin-top: 0.5rem;
	}

	/* Math Styles */
	:global(.math-display) {
		margin: 1rem 0 !important;
		background: rgba(255,255,255,0.5);
		padding: 1rem;
		border-radius: 8px;
	}
	:global(.math-inline) {
		color: #1e40af;
		font-weight: 600;
	}

	.practice-box {
		padding: 0.5rem;
		font-size: 1.15rem;
		line-height: 1.8;
	}

	.solving-space {
		margin-top: 1rem;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 1.5rem;
		flex: 1;
		min-height: 350px;
		display: flex;
		flex-direction: column;
		background: #fff;
	}
	.space-label {
		font-size: 0.8rem;
		font-weight: 800;
		color: #94a3b8;
		margin-bottom: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.dotted-area {
		flex: 1;
		background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
		background-size: 30px 30px;
	}

	.content-border {
		border: 1px solid #000;
		padding: 40px;
		height: 100%;
		display: flex;
		flex-direction: column;
		position: relative;
	}
	.watermark {
		position: absolute;
		top: 15px;
		right: 20px;
		font-size: 0.75rem;
		color: #94a3b8;
		font-weight: 800;
		letter-spacing: 0.1em;
	}
	.exam-footer {
		margin-top: auto;
		padding-top: 3rem;
	}
	.footer-line { width: 100%; height: 2px; background: #000; margin-bottom: 1rem; }
	.footer-row {
		display: flex;
		justify-content: space-between;
		font-size: 0.85rem;
		font-weight: 700;
	}
</style>


