---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import katex from 'katex';

export async function getStaticPaths() {
	const vaultPath = path.join(process.cwd(), '../vault/m2-1-final/study');
	if (!fs.existsSync(vaultPath)) return [];
	const files = fs.readdirSync(vaultPath).filter(f => f.endsWith('.md'));
	return files.map(f => ({
		params: { id: f.replace('.md', '').replace(/^0/, '') }
	}));
}

const { id } = Astro.params;
const paddedId = String(id).padStart(2, '0');
const filePath = path.join(process.cwd(), `../vault/m2-1-final/study/${paddedId}.md`);

if (!fs.existsSync(filePath)) throw new Error(`Study file not found: ${filePath}`);
const content = fs.readFileSync(filePath, 'utf-8');

// --- Pre-rendering Logic (SSR) ---
function renderInlineMath(text: string): string {
	return text.replace(/\$([^\$\n]+?)\$/g, (_, tex) => {
		try {
			return `<span class="math-inline">${katex.renderToString(tex.trim(), { displayMode: false, output: 'html', throwOnError: false })}</span>`;
		} catch { return tex; }
	});
}

function renderDisplayMath(text: string): string {
	return text.replace(/\$\$(.*?)\$\$/gs, (_, tex) => {
		try {
			return `<div class="math-display">${katex.renderToString(tex.trim(), { displayMode: true, output: 'html', throwOnError: false })}</div>`;
		} catch { return tex; }
	});
}

function processContent(raw: string) {
	const segments = raw.split(':::');
	let cleaned = segments[0];
	
	for (let i = 1; i < segments.length; i += 2) {
		const block = segments[i];
		const nextText = segments[i+1] || '';
		
		const firstNewline = block.indexOf('\n');
		if (firstNewline !== -1) {
			const type = block.substring(0, firstNewline).trim();
			const content = block.substring(firstNewline).trim(); 
			cleaned += `<div class="card ${type}-card">${content}</div>` + nextText;
		} else {
			cleaned += block + nextText;
		}
	}

	cleaned = cleaned
		.replace(/### (.*)/g, '<div class="section-badge-wrapper"><div class="section-badge">$1</div></div>')
		.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
		.replace(/^> (.*)$/gm, '<blockquote>$1</blockquote>');

	cleaned = cleaned.replace(/★ (.*)/g, '<div class="star-item"><span class="star-icon">★</span> <span class="star-text">$1</span></div>');
	
	const instrHTML = renderInlineMath(cleaned);
	let restHTML = renderDisplayMath(instrHTML);
	
	// 카드가 아닌 일반 텍스트 영역의 줄바꿈만 <br/>로 변환
	const parts = restHTML.split(/(<div class="card .*?">.*?<\/div>|<div class="math-display">.*?<\/div>)/gs);
	restHTML = parts.map(p => {
		if (p.startsWith('<div class="card') || p.startsWith('<div class="math-display">')) return p;
		return p.trim().replace(/\n/g, '<br/>');
	}).join('');

	return restHTML;
}

// --- Parse Study Page ---
const lines = content.split('\n');
const title = lines[0].replace('# ', '').trim();
const body = lines.slice(1).join('\n').trim();

const section = {
	title,
	content: processContent(body)
};

// --- JSON-LD for AEO/GEO ---
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "LearningResource",
	"name": section.title,
	"description": `중학교 2학년 수학 기말고사 대비를 위한 ${section.title} 핵심 개념 정리 및 연습 문제입니다.`,
	"learningResourceType": "Concept Summary and Practice",
	"educationalLevel": "Middle School Grade 2",
	"about": section.title.split(':')[1]?.trim() || "수학"
};
---

<Layout title={`마스터 ${id} - ${section.title.split(':')[1]?.trim()}`}>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<div class="paper-stack">
		<div class="paper study-page" id={`page-study-${id}`}>
			<div class="content-border">
				<div class="watermark">MASTER PLAN : CONCEPT & PRACTICE</div>
				
				<header class="study-header">
					<div class="header-top">
						<div class="nav-group">
							<span class="id-label">MASTER PAGE {String(id).padStart(2, '0')}</span>
							<a href="/math_m2/" class="home-link" title="전체 목록보기">🏠</a>
						</div>
					</div>
					<h2 class="study-title">{section.title}</h2>
				</header>

				<div class="study-content">
					<div class="concept-section" set:html={section.content}></div>
				</div>

				<footer class="exam-footer">
					<div class="footer-line"></div>
					<div class="footer-row">
						<span class="brand">Somath Digital Library</span>
						<span class="page-num">{parseInt(id || '1') + 1} / 3</span>
						<span class="copy">© 2026 Math Basic Project</span>
					</div>
				</footer>
			</div>
		</div>
	</div>
</Layout>

<style>
	:root {
		--ink: #1e293b;
		--paper: #fff;
		--point-blue: #2563eb;
		--bg-blue: #f8fafc;
		--point-red: #ef4444;
		--point-green: #10b981;
	}

	.paper {
		background: var(--paper);
		color: var(--ink);
		padding: 40px;
		box-sizing: border-box;
		min-height: 297mm;
		width: 100%;
		max-width: 210mm;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
	}

	@media (max-width: 768px) {
		.paper {
			padding: 15px;
			min-height: auto;
			box-shadow: none;
		}
	}

	.paper-stack {
		display: flex;
		justify-content: center;
		padding: 2rem 0;
	}

	@media (max-width: 768px) {
		.paper-stack {
			padding: 0;
		}
	}

	.study-header {
		border-bottom: 2px solid var(--ink);
		margin-bottom: 3rem;
		padding: 4rem 0 0.8rem 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
	}

	.header-top {
		display: flex;
		justify-content: flex-start;
		margin-bottom: 0.6rem;
	}
	.nav-group {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.home-link {
		text-decoration: none;
		font-size: 1.4rem;
		line-height: 1;
		transition: transform 0.2s ease;
		display: flex;
		align-items: center;
		margin-top: 0.1rem;
	}
	.home-link:hover {
		transform: scale(1.15);
	}
	.id-label {
		font-family: sans-serif;
		font-size: 1.1rem;
		font-weight: 800;
		color: #475569;
		letter-spacing: -0.01em;
		text-transform: uppercase;
	}
	.study-title {
		font-size: 2.4rem;
		margin: 0 0 1rem 0;
		color: #0f172a;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.study-content {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.section-badge {
		display: inline-flex;
		align-items: center;
		background: #0f172a;
		color: #fff;
		padding: 6px 16px;
		border-radius: 20px 20px 20px 0;
		font-size: 1rem;
		font-weight: bold;
		margin-bottom: 1.5rem;
		box-shadow: 3px 3px 0px var(--point-blue);
	}
	.badge-icon { margin-right: 6px; }

	:global(.card) {
		border-radius: 16px;
		padding: 2rem 2.5rem;
		margin-bottom: 2rem;
		line-height: 1.6;
		font-size: 1.1rem;
		position: relative;
		border: 2px solid rgba(0,0,0,0.03);
		box-shadow: 0 4px 15px rgba(0,0,0,0.02);
		word-break: keep-all;
		letter-spacing: -0.02em;
		text-align: left;
	}
	:global(.info-card) {
		background: linear-gradient(135deg, #f0f7ff 0%, #e0f2fe 100%);
		border-color: #bae6fd;
	}
	:global(.danger-card) {
		background: linear-gradient(135deg, #fff5f5 0%, #fff1f1 100%);
		border-color: #fecaca;
	}
	:global(.success-card) {
		background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
		border-color: #bbf7d0;
	}

	:global(.card strong) {
		display: block;
		font-size: 1.2rem;
		margin-bottom: 1rem;
		color: #0f172a;
		font-weight: 800;
	}

	:global(.star-item) {
		display: flex;
		align-items: flex-start;
		gap: 0.8rem;
		margin-bottom: 0.8rem;
		font-weight: 600;
	}
	:global(.star-icon) {
		color: #f59e0b;
		font-size: 1.2rem;
		margin-top: 0.15rem;
		flex-shrink: 0;
	}

	:global(blockquote) {
		margin: 0.5rem 0 1.8rem 0;
		padding: 1rem 1.5rem;
		background: rgba(255, 255, 255, 0.9);
		border: 2.5px dashed var(--point-blue);
		border-radius: 12px;
		font-weight: 800;
		color: var(--point-blue);
		font-size: 1.2rem;
		text-align: center;
	}

	:global(.math-display) {
		margin: 0.8rem 0 !important;
		background: rgba(255,255,255,0.7);
		padding: 0.8rem;
		border-radius: 8px;
		border: 1px solid rgba(0,0,0,0.05);
	}
	:global(.math-inline) {
		color: #1e40af;
		font-weight: 600;
		margin-left: 0.05em !important;
		margin-right: -0.15em !important;
		display: inline-block;
		vertical-align: baseline;
	}

	.content-border {
		border: 1px solid #000;
		padding: 40px;
		height: 100%;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	@media (max-width: 768px) {
		.content-border {
			padding: 20px 15px;
		}
		
		.study-title {
			font-size: 1.8rem;
		}

		:global(.card) {
			padding: 1.2rem 1rem;
			font-size: 1rem;
		}

		:global(.card strong) {
			font-size: 1.1rem;
		}

		:global(blockquote) {
			font-size: 1.1rem;
			padding: 0.8rem;
		}
	}
	.watermark {
		position: absolute;
		top: 15px;
		right: 20px;
		font-size: 0.75rem;
		color: #94a3b8;
		font-weight: 800;
		letter-spacing: 0.1em;
	}
	.exam-footer {
		margin-top: auto;
		padding-top: 3rem;
	}
	.footer-line { width: 100%; height: 2px; background: #000; margin-bottom: 1rem; }
	.footer-row {
		display: flex;
		justify-content: space-between;
		font-size: 0.85rem;
		font-weight: 700;
	}
</style>
