		margin: 0.15rem 0 0.25rem 0 !important;
		padding-left: 1.5rem;
		text-align: left !important;
	}
	:global(.math-inline) {
		white-space: normal;
	}
	:global(.katex-display) {
		margin: 0 !important;
		text-align: left !important;
	}
	:global(.katex-display > .katex) {
