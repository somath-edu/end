	.footer-row {
		display: flex;
		justify-content: space-between;
		font-size: 0.8rem;
		font-weight: 600;
	}

	@media (max-width: 900px) {
		.paper { padding: 20px; }
		.columns-wrapper { gap: 2rem; }
	}

	@media (max-width: 768px) {
		.columns-wrapper { flex-direction: column; gap: 0; }
		.vertical-divider { display: none; }
		.column:first-child { border-bottom: 1px dashed #ccc; margin-bottom: 2rem; padding-bottom: 1rem; }
		.exam-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
		.student-info-box { width: 100%; }
		.paper { padding: 15px; }
	}
</style>